{
  "version": "1.0",
  "smoke_scenarios": ["known-dto-field", "unfamiliar-login-trace", "authentication-policy", "security-read-only-analysis"],
  "scenarios": [
    {
      "id": "known-dto-field",
      "prompt": "Add one displayName property to the known UserDto file and update its existing mapping",
      "allowed_lanes": ["single-agent"],
      "required_roles": [],
      "allowed_roles": [],
      "max_role_counts": {},
      "max_subagents": 0,
      "approval_required": false
    },
    {
      "id": "unfamiliar-login-trace",
      "prompt": "Limited main-agent exploration of the large repository did not converge. Independently trace the unfamiliar login flow from the Vue page through the API and repository without changing files; broad searches produce substantial intermediate evidence, so isolate that noise and stop once the end-to-end call chain can be returned as a concise path-and-line report",
      "allowed_lanes": ["plan-light"],
      "required_roles": ["explorer"],
      "allowed_roles": ["explorer"],
      "max_role_counts": { "explorer": 1 },
      "max_subagents": 1,
      "approval_required": false
    },
    {
      "id": "known-crud-edits",
      "prompt": "Apply three related CRUD edits in known files with existing unit tests",
      "allowed_lanes": ["single-agent", "plan-light"],
      "required_roles": [],
      "allowed_roles": [],
      "max_role_counts": {},
      "max_subagents": 0,
      "approval_required": false
    },
    {
      "id": "large-ci-log",
      "prompt": "Analyze a very large CI log, identify the first actionable failure, and return concise evidence without editing files",
